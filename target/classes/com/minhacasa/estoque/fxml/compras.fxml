<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minhacasa.estoque.controller.ComprasController"
      styleClass="view-padding">

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="2">
            <Label text="Compras / Entradas" styleClass="section-title" style="-fx-font-size: 19px;"/>
            <Label fx:id="subtitleLabel" styleClass="section-subtitle"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="+ Registrar Compra" styleClass="btn-primary" onAction="#onNovo"/>
    </HBox>

    <TableView fx:id="tabela" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colData" text="DATA" prefWidth="100"/>
            <TableColumn fx:id="colEquipamento" text="EQUIPAMENTO" prefWidth="210"/>
            <TableColumn fx:id="colFornecedor" text="FORNECEDOR" prefWidth="190"/>
            <TableColumn fx:id="colQtd" text="QTD" prefWidth="60"/>
            <TableColumn fx:id="colCusto" text="CUSTO UNIT." prefWidth="110"/>
            <TableColumn fx:id="colTotal" text="TOTAL" prefWidth="110"/>
            <TableColumn fx:id="colTipo" text="" prefWidth="90"/>
        </columns>
    </TableView>

</VBox>
