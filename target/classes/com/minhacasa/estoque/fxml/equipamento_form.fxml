<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minhacasa.estoque.controller.EquipamentoFormController"
      styleClass="modal-card" spacing="18">

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="titleLabel" text="Novo Equipamento" styleClass="modal-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="modal-close-btn" onAction="#onCancelar"/>
    </HBox>

    <VBox spacing="5">
        <Label text="NOME *" styleClass="form-label"/>
        <TextField fx:id="nomeField" styleClass="text-field"/>
    </VBox>

    <HBox spacing="14">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="Nº DE SÉRIE *" styleClass="form-label"/>
            <TextField fx:id="serieField" styleClass="text-field"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="PREÇO (R$) *" styleClass="form-label"/>
            <TextField fx:id="precoField" styleClass="text-field" promptText="0"/>
        </VBox>
    </HBox>

    <VBox spacing="5">
        <Label text="QUANTIDADE *" styleClass="form-label"/>
        <TextField fx:id="quantidadeField" styleClass="text-field" promptText="0"/>
    </VBox>

    <HBox spacing="14">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="LOCAL" styleClass="form-label"/>
            <ComboBox fx:id="localCombo" maxWidth="Infinity" promptText="Selecione..."/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="RESPONSÁVEL" styleClass="form-label"/>
            <ComboBox fx:id="responsavelCombo" maxWidth="Infinity" promptText="Selecione..."/>
        </VBox>
    </HBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-link" onAction="#onCancelar"/>
        <Button text="✓ Salvar" styleClass="btn-primary" onAction="#onSalvar"/>
    </HBox>

</VBox>
