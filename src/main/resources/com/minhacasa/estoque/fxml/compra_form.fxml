<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minhacasa.estoque.controller.CompraFormController"
      styleClass="modal-card" spacing="18">

    <HBox alignment="CENTER_LEFT">
        <Label text="Registrar Compra" styleClass="modal-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="modal-close-btn" onAction="#onCancelar"/>
    </HBox>

    <VBox spacing="5">
        <Label text="EQUIPAMENTO *" styleClass="form-label"/>
        <ComboBox fx:id="equipamentoCombo" maxWidth="Infinity" promptText="Selecione..."/>
    </VBox>

    <VBox spacing="5">
        <Label text="FORNECEDOR" styleClass="form-label"/>
        <TextField fx:id="fornecedorField" styleClass="text-field"/>
    </VBox>

    <HBox spacing="14">
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="QUANTIDADE *" styleClass="form-label"/>
            <TextField fx:id="quantidadeField" styleClass="text-field" promptText="1"/>
        </VBox>
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <Label text="CUSTO UNIT. (R$)" styleClass="form-label"/>
            <TextField fx:id="custoField" styleClass="text-field" promptText="0"/>
        </VBox>
    </HBox>

    <VBox spacing="5">
        <Label text="DATA *" styleClass="form-label"/>
        <DatePicker fx:id="dataPicker" maxWidth="Infinity"/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-link" onAction="#onCancelar"/>
        <Button text="✓ Salvar" styleClass="btn-primary" onAction="#onSalvar"/>
    </HBox>

</VBox>
