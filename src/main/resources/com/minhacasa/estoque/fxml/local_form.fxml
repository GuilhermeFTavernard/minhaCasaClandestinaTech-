<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.minhacasa.estoque.controller.LocalFormController"
      styleClass="modal-card" spacing="18">

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="titleLabel" text="Novo Local" styleClass="modal-title"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="✕" styleClass="modal-close-btn" onAction="#onCancelar"/>
    </HBox>

    <VBox spacing="5">
        <Label text="CASA *" styleClass="form-label"/>
        <TextField fx:id="casaField" styleClass="text-field" promptText="Ex.: Casa do Toinho"/>
    </VBox>

    <VBox spacing="5">
        <Label text="COMPARTIMENTO *" styleClass="form-label"/>
        <TextField fx:id="compartimentoField" styleClass="text-field" promptText="Ex.: Quarto da mãe"/>
    </VBox>

    <VBox spacing="5">
        <Label text="RESPONSÁVEL" styleClass="form-label"/>
        <ComboBox fx:id="responsavelCombo" maxWidth="Infinity" promptText="Selecione..."/>
    </VBox>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar" styleClass="btn-link" onAction="#onCancelar"/>
        <Button text="✓ Salvar" styleClass="btn-primary" onAction="#onSalvar"/>
    </HBox>

</VBox>
