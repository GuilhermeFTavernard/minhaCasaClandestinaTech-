<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.minhaCasaClandestinaTech.controller.LoginController"
           styleClass="login-bg">

    <VBox styleClass="login-card" spacing="18" maxWidth="420" maxHeight="420">

        <!-- Logo / Título -->
        <VBox alignment="CENTER" spacing="6">
            <Label text="M.C.C.TECH" styleClass="login-title"/>
        </VBox>

        <!-- Campo Email -->
        <VBox spacing="5">
            <Label text="Email:" styleClass="form-label"/>
            <TextField fx:id="emailField" styleClass="text-field" promptText="seu@email.com"/>
        </VBox>

        <!-- Campo Senha -->
        <VBox spacing="5">
            <Label text="Senha:" styleClass="form-label"/>
            <PasswordField fx:id="senhaField" styleClass="text-field" promptText="••••••••"/>
            <Hyperlink text="Não tem uma conta? Cadastre-se" onAction="#onCadastrar"
                       styleClass="link-cadastro"/>
        </VBox>

        <!-- Mensagem de erro -->
        <Label fx:id="erroLabel" styleClass="login-erro" managed="false" visible="false"/>

        <!-- Botão Login -->
        <Button text="Login" styleClass="btn-primary" maxWidth="Infinity"
                defaultButton="true" onAction="#onLogin"/>

    </VBox>

</StackPane>
