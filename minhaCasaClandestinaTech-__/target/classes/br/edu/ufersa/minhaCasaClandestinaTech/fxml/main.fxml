<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="br.edu.ufersa.minhaCasaClandestinaTech.controller.MainController">

    <BorderPane fx:id="rootBorderPane">
        <top>
            <VBox>
                <HBox styleClass="page-header-bar" alignment="CENTER_LEFT">
                    <Label fx:id="pageTitleLabel" text="Dashboard" styleClass="page-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="dateLabel" styleClass="page-date"/>
                </HBox>
            </VBox>
        </top>

        <left>
            <VBox styleClass="sidebar">
                <HBox styleClass="sidebar-logo-box">
                    <StackPane styleClass="sidebar-logo-icon">
                        <Label text="🖥" styleClass="sidebar-logo-icon-text"/>
                    </StackPane>
                    <VBox spacing="1">
                        <Label text="minhaCasa" styleClass="sidebar-brand-title"/>
                        <Label text="ClandestinaTech" styleClass="sidebar-brand-subtitle"/>
                    </VBox>
                </HBox>

                <VBox styleClass="sidebar-menu">
                    <Button fx:id="btnDashboard" text="🏠   Dashboard" styleClass="menu-button"
                            onAction="#onDashboard" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnEquipamentos" text="💻   Equipamentos" styleClass="menu-button"
                            onAction="#onEquipamentos" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnLocais" text="📍   Locais" styleClass="menu-button"
                            onAction="#onLocais" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnResponsaveis" text="🧑   Responsáveis" styleClass="menu-button"
                            onAction="#onResponsaveis" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnClientes" text="👥   Clientes" styleClass="menu-button"
                            onAction="#onClientes" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnVendas" text="🛒   Vendas" styleClass="menu-button"
                            onAction="#onVendas" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnCompras" text="📦   Compras" styleClass="menu-button"
                            onAction="#onCompras" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                    <Button fx:id="btnRelatorios" text="📊   Relatórios" styleClass="menu-button"
                            onAction="#onRelatorios" maxWidth="Infinity" alignment="CENTER_LEFT"/>
                </VBox>

                <Region VBox.vgrow="ALWAYS"/>

                <VBox styleClass="sidebar-footer">
                    <Label text="v1.0 · 2026" styleClass="sidebar-footer-text"/>
                    <Label text="Toinho &amp; Kanalense" styleClass="sidebar-footer-text"/>
                </VBox>
            </VBox>
        </left>

        <center>
            <ScrollPane fitToWidth="true" styleClass="content-scroll" BorderPane.alignment="CENTER">
                <StackPane fx:id="contentArea" styleClass="content-area"/>
            </ScrollPane>
        </center>
    </BorderPane>

    <StackPane fx:id="modalOverlay" styleClass="modal-overlay" visible="false" managed="false"
               alignment="CENTER" onMouseClicked="#onOverlayClicked">
        <StackPane fx:id="modalContainer" maxWidth="-Infinity" maxHeight="-Infinity"/>
    </StackPane>

</StackPane>
